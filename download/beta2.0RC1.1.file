@echo off
chcp 65001 >nul 2>&1  :: 解决中文乱码
setlocal enabledelayedexpansion

:: ========== 配置项（根据你的软件修改） ==========
:: 软件下载地址
set "SOFT_URL=https://developer-oss.lanrar.com/file/?&toolsdown"
:: 软件保存路径（默认下载到用户桌面，避免权限问题）
set "SOFT_SAVE_PATH=%USERPROFILE%\Desktop\SyncTunnel-beta2.0RC1.1.exe"

:: ========== 检查curl是否存在（Win10 1803+自带，Win7需手动装） ==========
curl --version >nul 2>&1
if errorlevel 1 (
    echo [错误] 未找到curl，请先安装curl或升级Windows到10 1803以上版本！
    echo 备用方案：自动用PowerShell下载...
    :: 兜底：用PowerShell下载（所有Windows版本都有PowerShell）
    powershell -Command "(New-Object System.Net.WebClient).DownloadFile('%SOFT_URL%', '%SOFT_SAVE_PATH%')"
) else (
    echo [信息] 开始下载软件（beta2.0RC1.1）...
    :: 用curl下载（静默模式，显示进度）
    curl -# -O -L "%SOFT_URL%" --output "%SOFT_SAVE_PATH%"
)


:: ========== 运行软件 ==========
echo [信息] 启动软件（beta2.0RC1.1）...
start "" "%SOFT_SAVE_PATH%"

:: ========== 结束清理 ==========
echo [信息] 操作完成！软件已保存到：%SOFT_SAVE_PATH%
endlocal
pause >nul 2>&1  :: 可选：保留窗口，方便查看日志
